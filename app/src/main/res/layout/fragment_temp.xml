<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFF3E0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Convertisseur de température"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#E65100"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rgTemp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <RadioButton
            android:id="@+id/rbCtoF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Celsius → Fahrenheit"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbFtoC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fahrenheit → Celsius"
            android:layout_marginStart="18dp" />
    </RadioGroup>

    <EditText
        android:id="@+id/etTempInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Entrer une température"
        android:inputType="numberDecimal"
        android:backgroundTint="#FB8C00"
        android:layout_marginBottom="14dp" />

    <Button
        android:id="@+id/btnConvertTemp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Convertir"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FB8C00"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvTempResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Résultat : -"
        android:textSize="17sp"
        android:textStyle="italic"
        android:textColor="#BF360C"
        android:layout_marginTop="6dp" />
</LinearLayout>